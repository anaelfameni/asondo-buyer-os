# ===========================================================================
# LOCAL ENVIRONMENT - TEMPLATE
# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored - never commit your real keys.
# ===========================================================================

# Google Gemini API key for the AI Copilot
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================================================
# CEO CONSOLE (demo-grade auth, replace with Supabase/NextAuth for prod)
# ===========================================================================

# Password the CEO types on /console/login
CONSOLE_PASSWORD=change-me-to-a-strong-password

# Server-side cookie value issued after successful login.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONSOLE_SESSION_SECRET=replace-with-a-long-random-string
